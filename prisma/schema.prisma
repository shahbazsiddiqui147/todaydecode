generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Article {
  id                 String            @id @default(cuid())
  title              String
  slug               String            @unique
  onPageLead         String?
  summary            String
  content            String
  status             ArticleStatus     @default(DRAFT)
  format             PublicationFormat @default(STRATEGIC_REPORT)
  isFeatured         Boolean           @default(false)
  isFeaturedScenario Boolean           @default(false)
  featuredImage      String?
  featuredImageAlt   String?
  confidenceScore    Int?
  readingTime        Int?
  sourceUrls         String[]
  tags               String[]
  locale             String            @default("en")
  region             Region            @default(GLOBAL)
  riskLevel          RiskLevel         @default(MEDIUM)
  riskScore          Int
  impactScore        Int
  scenarios          Json?
  structuredData     Json?
  directAnswer       String?
  faqData            Json?
  auditNodes         String?
  researchArchive    String?
  metaTitle          String?
  metaDescription    String?
  publishedAt        DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  authorId           String
  categoryId         String
  isPremium          Boolean           @default(false)
  author             Author            @relation(fields: [authorId], references: [id])
  category           Category          @relation(fields: [categoryId], references: [id])
  savedBy            SavedAnalysis[]
}

model Category {
  id          String      @id @default(cuid())
  name        String      @unique
  slug        String      @unique
  description String?
  leadAnalyst String?     @default("Strategic Oversight Group")
  order       Int         @default(0)
  isVisible   Boolean     @default(true)
  icon        String?
  parentId    String?
  articles    Article[]
  submissions Submission[]
  parent      Category?   @relation("SubCategories", fields: [parentId], references: [id])
  children    Category[]  @relation("SubCategories")
  watchlists  Watchlist[]
}

model Author {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  image       String?
  role        String
  bio         String
  affiliation String?
  expertise   String[]
  socialLinks Json?
  articles    Article[]
}

model User {
  id                   String            @id @default(cuid())
  name                 String?
  email                String?           @unique
  emailVerified        DateTime?
  image                String?
  password             String?
  role                 UserRole          @default(GUEST)
  isApproved           Boolean           @default(false)
  institutionalBio     String?           @db.Text
  designation          String?
  affiliation          String?
  registrationType     RegistrationType?
  stripeCustomerId     String?           @unique
  stripeSubscriptionId String?           @unique
  accounts             Account[]
  savedAnalyses        SavedAnalysis[]
  sessions             Session[]
  watchlists           Watchlist[]
  submissions          Submission[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Watchlist {
  id         String    @id @default(cuid())
  userId     String
  categoryId String?
  region     Region?
  createdAt  DateTime  @default(now())
  category   Category? @relation(fields: [categoryId], references: [id])
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, region])
}

model SavedAnalysis {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  createdAt DateTime @default(now())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, articleId])
}

model Page {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  content         String
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SiteSettings {
  id              String   @id @default("1")
  siteName        String   @default("Today Decode")
  logoUrl         String?
  faviconUrl      String?
  socialLinks     Json?
  maintenanceMode Boolean  @default(false)
  globalRiskIndex Int      @default(50)
  updatedAt       DateTime @updatedAt
}

model NavigationItem {
  id        String   @id @default(cuid())
  label     String
  href      String
  order     Int      @default(0)
  type      String   @default("HEADER")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CountryMetric {
  id          String   @id @default(cuid())
  countryCode String   @unique
  countryName String
  literacy    String?
  economy     String?
  energy      String?
  defenceProfile String?
  riskScore   Int?
  updatedAt   DateTime @updatedAt
}

model Submission {
  id              String            @id @default(cuid())
  title           String
  summary         String
  content         String            @db.Text
  format          PublicationFormat @default(COMMENTARY)
  categoryId      String
  region          Region            @default(GLOBAL)
  sourceUrls      String[]
  status          SubmissionStatus  @default(PENDING)
  reviewNote      String?
  submittedAt     DateTime          @default(now())
  reviewedAt      DateTime?
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        Category          @relation(fields: [categoryId], references: [id])
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Region {
  GLOBAL
  MENA
  APAC
  EUROPE
  AMERICAS
  AFRICA
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum PublicationFormat {
  POLICY_BRIEF
  STRATEGIC_REPORT
  COMMENTARY
  SCENARIO_ANALYSIS
  RISK_ASSESSMENT
  DATA_INSIGHT
  ANNUAL_OUTLOOK
  POLICY_TOOLKIT
  NEWS_BRIEF
  CURRENT_AFFAIRS
}

enum UserRole {
  GUEST
  AUTHOR
  EDITOR
  ADMIN
}

enum RegistrationType {
  ACADEMIC
  ANALYST
  JOURNALIST
  PROFESSIONAL
  STUDENT
}

enum SubmissionStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
}
